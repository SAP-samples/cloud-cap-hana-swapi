{
  "name": "cap-hana-swapi",
  "version": "1.8.0",
  "description": "SAP Cloud Application Programming Model fun sample to demonstrate many-to-many relationships.",
  "repository": "https://github.com/SAP-samples/cloud-cap-hana-swapi",
  "license": "Apache-2.0",
  "private": false,
  "dependencies": {
    "@cap-js-community/odata-v2-adapter": "^1.15.10",
    "@cap-js/change-tracking": "^1.1.4",
    "@cap-js/graphql": "0.14.0",
    "@cap-js/hana": "^2.7.0",
    "@cap-js/notifications": "0.3.0",
    "@cap-js/postgres": "^2.2.0",
    "@cap-js/sqlite": "^2.2.0",
    "@cap-js/telemetry": "^1.6.0",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "9.8.3",
    "@sap/cds-common-content": "^3.1.0",
    "@sap/cds-fiori": "^2.3.0",
    "@sap/xb-msg-amqp-v100": "^0.9.58",
    "cds-swagger-ui-express": "^0.11.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "uuid": "^13.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start-local": "npm run generate-entry-point && npm run watch",
    "generate-entry-point": "dev-cap-tools gen-entrypoint",
    "build": "cds build",
    "build_sqlite": "cds deploy --profile sqlite",
    "build_pg": "cds deploy --profile pg",
    "hana": "cds deploy --to hana:starwars --auto-undeploy",
    "load": "cds bind --exec node convertData.js --profile hybrid",
    "load_sqlite": "cds bind --exec node convertData.js --profile sqlite",
    "load_pg": "cds bind --exec node convertData.js --profile pg",
    "test": "node --env-file=test/test.env --test --test-timeout 60000 test/model.test.js test/handler.test.js",
    "test:handler": "node --env-file=test/test.env --test --test-timeout 60000 test/handler.test.js",
    "test:profile": "node --env-file=test/test.env --test --test-timeout 60000 --test-name-pattern \"Profile-specific model exposure\" test/model.test.js",
    "test:migration": "node --test test/convertData.test.js test/convertData.report.test.js",
    "start": "cds-serve",
    "watch": "cds watch --profile hybrid --livereload false",
    "sqlite": "cds watch --profile sqlite --livereload false",
    "pg": "cds watch --profile pg --livereload false",
    "build2": "cp ./gen/db/.env ./ && cds build && cp ./.env ./gen/db/",
    "openapi": "cds compile srv --service all -o docs --to openapi --openapi:diagram",
    "asyncapi": "cds compile srv --service all -o docs --to asyncapi",
    "readme": "widdershins --summary docs/DataService.openapi3.json -o docs/DataService_readme.md && widdershins --summary docs/StarWarsFilm.openapi3.json -o docs/StarWarsFilm_readme.md",
    "helm": "helm upgrade --install swapi ./chart --namespace teched22",
    "changeLog": "node CHANGELOG.mjs",
    "packDb": "pack build cap-hana-swapi-hana-deployer --path gen/db --builder paketobuildpacks/builder-jammy-base",
    "pack": "pack build cap-hana-swapi-srv --path gen/srv --builder paketobuildpacks/builder-jammy-base"
  },
  "cds": {
    "cov2ap": {
      "plugin": true
    },
    "i18n": {
      "folders": [
        "_i18n"
      ]
    },
    "fiori": {
      "preview": {
        "ui5": {
          "version": "1.145.0"
        }
      }
    },
    "hana": {
      "journal": {
        "change-mode": "alter"
      },
      "deploy-format": "hdbtable"
    },
    "sql": {
      "native_hana_associations": false
    },
    "requires": {
      "queue": true,
      "middlewares": true,
      "db": {
        "kind": "sqlite",
        "impl": "@cap-js/sqlite",
        "credentials": {
          "url": "db.sqlite"
        },
        "schema_evolution": "auto"
      },
      "db-ext": {
        "model": "db/sqlite"
      },
      "[pg]": {
        "db": {
          "kind": "postgres",
          "dialect": "postgres",
          "impl": "@cap-js/postgres",
          "schema_evolution": "auto",
          "credentials": {
            "host": "localhost",
            "port": 5432,
            "db": "postgres"
          }
        },
        "db-ext": {
          "model": "db/postgres"
        }
      },
      "[hybrid]": {
        "db": {
          "kind": "hana-cloud",
          "impl": "@cap-js/hana"
        },
        "db-ext": {
          "model": "db/hana"
        }
      },
      "[production]": {
        "db": {
          "kind": "hana-cloud",
          "impl": "@cap-js/hana"
        },
        "db-ext": {
          "model": "db/hana"
        }
      },
      "messaging": {
        "[production]": {
          "kind": "enterprise-messaging"
        },
        "[development]": {
          "kind": "file-based-messaging"
        },
        "[hybrid]": {
          "kind": "file-based-messaging"
        }
      }
    },
    "features": {
      "kibana_formatter": true,
      "optimized_search": true
    },
    "protocols": {
      "graphql": {
        "path": "/graphql",
        "impl": "@cap-js/graphql"
      }
    },
    "log": {
      "service": true
    }
  },
  "devDependencies": {
    "@cap-js/cds-test": "^0.4.1",
    "@sap/dev-cap-tools": "^1.53.1",
    "@sap/eslint-plugin-cds": "^4.2.1",
    "@sap/hdi-deploy": "^5.6.1",
    "eslint": "10.0.3",
    "stringify-changelog": "^0.2.1",
    "widdershins": "^4.0.1"
  }
}
